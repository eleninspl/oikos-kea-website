# ─────────────────────────────────────────────────────────────────────────────
#  STUDIO (Sanity) — αντίγραψε αυτό το αρχείο σε `studio/.env` και συμπλήρωσε.
#  Το `studio/.env` είναι gitignored· ΜΗΝ βάζεις πραγματικά tokens εδώ στο example.
# ─────────────────────────────────────────────────────────────────────────────

# Project id / dataset — από https://sanity.io/manage.
# Απαιτείται για `sanity dev`, `sanity build`, `sanity deploy` και τα scripts.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Υποτομέας για `sanity deploy` → <host>.sanity.studio (προαιρετικό· default: oikos-kea).
SANITY_STUDIO_HOST=

# Write token — ΜΟΝΟ για τα maintenance scripts (scripts/*.ts) που ΓΡΑΦΟΥΝ δεδομένα.
# Πάρ' το από Sanity dashboard (API → Tokens, ρόλος Editor). ΜΗΝ το κάνεις commit.
SANITY_WRITE_TOKEN=
