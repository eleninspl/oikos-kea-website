# Astro → Sanity. Το site τραβάει το μενού στο build.
# Τα PUBLIC_* έχουν fallback τιμές στο src/lib/sanity.ts.
PUBLIC_SANITY_PROJECT_ID=s7x6np2r
PUBLIC_SANITY_DATASET=production

# Read-only token — απαιτείται (το dataset ζητάει token ακόμα και public).
# Build-time only· δεν φτάνει ποτέ στον browser. Πάρ' το από το Sanity dashboard
# (API → Tokens, ρόλος Viewer) ή ζήτα το από τον developer.
SANITY_READ_TOKEN=
