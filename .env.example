# ─────────────────────────────────────────────────────────────────────────────
#  SITE (Astro) — αντίγραψε αυτό το αρχείο σε `.env` και συμπλήρωσε τις τιμές.
#  Το `.env` είναι gitignored· ΜΗΝ βάζεις πραγματικά secrets εδώ στο example.
# ─────────────────────────────────────────────────────────────────────────────

# Sanity project — το site τραβάει το μενού στο build. Πάρε το id από
# https://sanity.io/manage. Αν μείνει κενό, το site πέφτει αυτόματα στα τοπικά
# seed δεδομένα (src/i18n/menuData.ts) — χρήσιμο για πρώτο boot του template.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Read-only token — απαιτείται (το dataset ζητάει token ακόμα κι αν είναι public).
# Build-time only· δεν φτάνει ΠΟΤΕ στον browser. Πάρ' το από το Sanity dashboard
# (API → Tokens, ρόλος Viewer).
SANITY_READ_TOKEN=
