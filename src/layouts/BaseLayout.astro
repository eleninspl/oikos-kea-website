---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getAlternateUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogImage?: string;
  pageType?: 'website' | 'article';
}

const {
  title,
  description,
  lang,
  ogImage = '/images/brand/og-image.jpg',
  pageType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const alternateLang = lang === 'el' ? 'en' : 'el';
const alternateURL = new URL(getAlternateUrl(Astro.url.pathname, alternateLang), Astro.site);
const ogLocale = lang === 'el' ? 'el_GR' : 'en_GB';

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'OIKOS',
  description: lang === 'el'
    ? 'All day cuisine bar στην Κορρησία, Κέα. Brunch, σούσι, cocktails και πολλά άλλα.'
    : 'All day cuisine bar in Korrisia, Kéa. Brunch, sushi, cocktails and more.',
  url: 'https://oikoskea.gr',
  telephone: '+302288022507',
  email: 'info@oikoskea.gr',
  servesCuisine: ['Mediterranean', 'Japanese', 'Brunch', 'Cocktails'],
  priceRange: '€€',
  image: ogImageURL.toString(),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.7',
    reviewCount: '330',
    bestRating: '5',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Korrisia',
    addressLocality: 'Kéa',
    addressRegion: 'Cyclades',
    postalCode: '84002',
    addressCountry: 'GR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 37.6442,
    longitude: 24.3326,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '09:00',
      closes: '02:00',
    },
  ],
  sameAs: ['https://www.instagram.com/oikos_kea/'],
};
---

<!doctype html>
<html lang={lang === 'el' ? 'el' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={lang === 'el' ? 'el' : 'en'} href={canonicalURL} />
    <link rel="alternate" hreflang={lang === 'el' ? 'en' : 'el'} href={alternateURL} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />

    <!-- Open Graph -->
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="OIKOS Kéa" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icons/favicon-180.png" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
  </head>
  <body>
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      const nav = document.querySelector('.nav');
      const burger = document.querySelector('.nav__burger');
      const mobileMenu = document.querySelector('.nav__mobile');

      let scrolled = false;
      window.addEventListener(
        'scroll',
        () => {
          const isScrolled = window.scrollY > 20;
          if (isScrolled !== scrolled) {
            scrolled = isScrolled;
            nav?.classList.toggle('nav--scrolled', isScrolled);
          }
        },
        { passive: true }
      );

      burger?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.toggle('open');
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });

      mobileMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
          document.body.style.overflow = '';
        });
      });
    </script>
  </body>
</html>
