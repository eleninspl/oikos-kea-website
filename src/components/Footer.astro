---
import { useTranslations, langBase } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { site } from '../lib/site';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const base = langBase(lang);
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <a href={base + '/'} class="footer__brand" aria-label="OIKOS Kea — Αρχική">
          <img src="/images/brand/logo-wordmark.png" alt="" width="450" height="106" />
        </a>
      </div>

      <div>
        <div class="footer__heading">{t('footer.nav')}</div>
        <ul class="footer__links">
          <li><a href={base + '/'} class="footer__link">{t('nav.home')}</a></li>
          <li><a href={base + '/menu'} class="footer__link">{t('nav.menu')}</a></li>
          <li><a href={base + '/about'} class="footer__link">{t('nav.about')}</a></li>
          <li><a href={base + '/contact'} class="footer__link">{t('nav.contact')}</a></li>
        </ul>
      </div>

      <div>
        <div class="footer__heading">{t('footer.find')}</div>
        <ul class="footer__links">
          <li class="footer__link">{t('contact.address.val')}</li>
          <li class="footer__link">{t('contact.address.sub')}</li>
          <li><a href={`tel:${site.phoneTel}`} class="footer__link">+30 {site.phoneDisplay}</a></li>
          <li><a href={`mailto:${site.email}`} class="footer__link">{site.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} {t('footer.copyright')}</span>
      <div class="footer__social">
        <a href={site.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
