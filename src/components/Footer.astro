---
import { useTranslations, langBase } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { site } from '../lib/site';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const base = langBase(lang);
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <a href={base + '/'} class="footer__brand" aria-label={`OIKOS Kea — ${t('nav.home')}`}>
          <img src="/images/brand/logo-wordmark.png" alt="" width="450" height="106" />
        </a>
      </div>

      <div>
        <div class="footer__heading">{t('footer.nav')}</div>
        <ul class="footer__links">
          <li><a href={base + '/'} class="footer__link">{t('nav.home')}</a></li>
          <li><a href={base + '/menu'} class="footer__link">{t('nav.menu')}</a></li>
          <li><a href={base + '/about'} class="footer__link">{t('nav.about')}</a></li>
          <li><a href={base + '/contact'} class="footer__link">{t('nav.contact')}</a></li>
        </ul>
      </div>

      <div>
        <div class="footer__heading">{t('footer.find')}</div>
        <ul class="footer__links">
          <li><a href={site.googleMaps} target="_blank" rel="noopener noreferrer" class="footer__link">{t('contact.address.val')}</a></li>
          <li><a href={`tel:${site.phoneTel}`} class="footer__link">+30 {site.phoneDisplay}</a></li>
          <li><a href={`mailto:${site.email}`} class="footer__link">{site.email}</a></li>
          <li><a href={site.instagram} target="_blank" rel="noopener noreferrer" class="footer__link">@oikos_kea</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} {t('footer.copyright')}</span>
    </div>
  </div>
</footer>
