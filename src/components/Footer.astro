---
import { Image } from 'astro:assets';
import { useTranslations, langBase } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { site } from '../lib/site';
import logoWordmark from '../assets/images/brand/logo-wordmark.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const base = langBase(lang);
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <a
          href={base + '/'}
          class="footer__brand"
          aria-label={`${site.brand.name} Kea — ${t('nav.home')}`}
        >
          <Image src={logoWordmark} alt="" width={450} height={106} loading="lazy" />
        </a>
      </div>

      <div>
        <div class="footer__heading">{t('footer.nav')}</div>
        <ul class="footer__links">
          <li><a href={base + '/'} class="footer__link">{t('nav.home')}</a></li>
          <li><a href={base + '/menu'} class="footer__link">{t('nav.menu')}</a></li>
          <li><a href={base + '/about'} class="footer__link">{t('nav.about')}</a></li>
          <li><a href={base + '/contact'} class="footer__link">{t('nav.contact')}</a></li>
        </ul>
      </div>

      <div>
        <div class="footer__heading">{t('footer.find')}</div>
        <ul class="footer__links">
          <li>
            <a
              href={site.social.googleMaps}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__link">{t('contact.address.val')}</a
            >
          </li>
          <li>
            <a href={`tel:${site.contact.phoneTel}`} class="footer__link"
              >{site.contact.phoneDisplayIntl}</a
            >
          </li>
          <li>
            <a href={`mailto:${site.contact.email}`} class="footer__link">{site.contact.email}</a>
          </li>
          <li>
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__link">{site.social.instagramHandle}</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} {t('footer.copyright')}</span>
    </div>
  </div>
</footer>

<style>
  /* ─── Footer ─── */
  .footer {
    background-color: var(--color-dark);
    color: rgb(from var(--brand-cream) r g b / 0.7);
    padding-block: var(--space-16);
    border-top: 1px solid rgb(from var(--brand-accent) r g b / 0.15);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .footer__brand {
    display: inline-flex;
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .footer__brand img {
    height: 30px;
    width: auto;
    display: block;
  }

  .footer__heading {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: rgb(from var(--brand-cream) r g b / 0.65);
    transition: color var(--transition-fast);
  }
  .footer__link:hover {
    color: var(--color-cream);
  }

  .footer__insta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer__bottom {
    border-top: 1px solid rgb(from var(--brand-cream) r g b / 0.08);
    padding-top: var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: rgb(from var(--brand-cream) r g b / 0.4);
  }

  .footer__social {
    display: flex;
    gap: var(--space-4);
  }

  .footer__social a {
    display: inline-flex;
    color: rgb(from var(--brand-cream) r g b / 0.5);
    transition: color var(--transition-fast);
  }
  .footer__social a:hover {
    color: var(--color-gold);
  }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }
  }
</style>
