---
import type { Item } from '../i18n/menuData';
import type { Lang } from '../i18n/utils';
import { labelText, allergenText, formatPrice } from '../lib/menuLabels';

interface Props {
  item: Item;
  lang: Lang;
}
const { item, lang } = Astro.props;

// Πέσε πίσω στο άλλο locale αν λείπει το όνομα (ο owner μπορεί να αφήσει κενό το EN στο CMS).
const name = (lang === 'el' ? item.nameEl : item.nameEn) || item.nameEl || item.nameEn;
const desc = lang === 'el' ? item.descEl : item.descEn;
const info = lang === 'el' ? item.infoEl : item.infoEn; // legacy (seed fallback)

// ── Τιμές: δομημένο μοντέλο, με fallback στα legacy πεδία ──
type Rendered = { label?: string; text: string };
let priceParts: Rendered[] = [];
if (item.prices && item.prices.length) {
  priceParts = item.prices.map((p) => ({
    label: (lang === 'el' ? p.labelEl : p.labelEn) || p.labelEl || p.labelEn || undefined,
    text: formatPrice(p.amount),
  }));
} else if (item.price || item.glass || item.priceAlt) {
  if (item.glass) priceParts.push({ label: lang === 'el' ? 'Ποτ.' : 'Glass', text: item.glass });
  if (item.price) priceParts.push({ text: item.price });
  if (item.priceAlt) priceParts.push({ text: item.priceAlt });
}

const labels = item.labels ?? [];
const allergens = item.allergens ?? [];
const extras = item.extras ?? [];
const unavailable = item.available === false;
const allergenLine = allergens.map((a) => allergenText(a, lang)).join(', ');
const soldOut = lang === 'el' ? 'Εξαντλήθηκε' : 'Sold out';
---

<div
  class:list={[
    'menu-item',
    { 'menu-item--unavailable': unavailable, 'menu-item--has-img': !!item.image },
  ]}
>
  <div class="menu-item__body">
    <div class="menu-item__name">
      {name}
      {labels.map((l) => <span class="menu-item__label">{labelText(l, lang)}</span>)}
      {unavailable && <span class="menu-item__label menu-item__label--out">{soldOut}</span>}
    </div>
    {info && <div class="menu-item__info">{info}</div>}
    {
      desc && (
        <div class="menu-item__desc">
          {desc.includes(' · ')
            ? desc.split(' · ').map((part) => <span class="menu-item__desc-line">{part}</span>)
            : desc}
        </div>
      )
    }
    {
      extras.map((e) => (
        <div class="menu-item__extra">
          + {lang === 'el' ? e.labelEl : e.labelEn || e.labelEl}
          {e.surcharge != null && <span> {formatPrice(e.surcharge)}</span>}
        </div>
      ))
    }
    {
      allergenLine && (
        <div class="menu-item__allergens">
          {lang === 'el' ? 'Αλλεργιογόνα: ' : 'Allergens: '}
          {allergenLine}
        </div>
      )
    }
  </div>
  <div class="menu-item__side">
    <div class="menu-item__price-wrap">
      {
        priceParts.map((p) => (
          <span class="menu-item__price">
            {p.label && <span class="menu-item__price-label">{p.label} </span>}
            {p.text}
          </span>
        ))
      }
      {item.priceNote && <span class="menu-item__price-note">{item.priceNote}</span>}
    </div>
    {
      item.image && (
        <img
          class="menu-item__img"
          src={item.image}
          alt=""
          loading="lazy"
          decoding="async"
          width="80"
          height="80"
        />
      )
    }
  </div>
</div>

<style>
  /* ─── Menu item (μία γραμμή προϊόντος) ─── */
  .menu-item {
    padding: var(--space-4) 0;
    border-bottom: 1px solid rgb(from var(--brand-ink) r g b / 0.08);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .menu-item__body {
    flex: 1;
    min-width: 0;
  }

  .menu-item__name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-dark);
  }

  .menu-item__info {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: 2px;
    font-style: italic;
    line-height: 1.5;
  }

  .menu-item__desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: var(--space-1);
    line-height: 1.55;
  }

  .menu-item__desc-line {
    display: block;
  }

  .menu-item__price-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
  }

  .menu-item__price {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-gold-dim);
    white-space: nowrap;
  }

  .menu-item__price-label {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.85em;
  }

  /* Σημείωση τιμής (π.χ. «τιμή ημέρας») — κάτω από την τιμή */
  .menu-item__price-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-style: italic;
    white-space: nowrap;
  }

  .menu-item--unavailable {
    opacity: 0.5;
  }

  /* Δεξιά στήλη: τιμή + εικόνα */
  .menu-item__side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  /* Φωτό προϊόντος (Sanity/external ή τοπικό fallback — μένει <img>) */
  .menu-item__img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
    cursor: zoom-in;
  }

  /* Ετικέτες (vegan, spicy…) */
  .menu-item__label {
    display: inline-block;
    margin-left: var(--space-2);
    padding: 1px 8px;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-dark);
    background: rgb(from var(--brand-accent) r g b / 0.22);
    border-radius: var(--radius-full);
    vertical-align: middle;
    white-space: nowrap;
  }
  .menu-item__label--out {
    background: rgb(from var(--brand-accent) r g b / 0.25);
    color: #8a5a1f;
  }

  /* Έξτρα προσθήκες */
  .menu-item__extra {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: 3px;
  }

  /* Αλλεργιογόνα */
  .menu-item__allergens {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-1);
    font-style: italic;
  }
</style>
