---
import type { Item } from '../i18n/menuData';
import type { Lang } from '../i18n/utils';

interface Props { item: Item; lang: Lang; }
const { item, lang } = Astro.props;

const name = lang === 'el' ? item.nameEl : item.nameEn;
const info = lang === 'el' ? item.infoEl : item.infoEn;
const desc = lang === 'el' ? item.descEl : item.descEn;
const glassLabel = lang === 'el' ? 'Ποτ.' : 'Glass';
---

<div class:list={['menu-item', { 'menu-item--wine': !!item.infoEl }]}>
  <div class="menu-item__body">
    <div class="menu-item__name">{name}</div>
    {info && <div class="menu-item__info">{info}</div>}
    {desc && <div class="menu-item__desc">{desc}</div>}
  </div>
  <div class="menu-item__price-wrap">
    {item.glass && <span class="menu-item__price-glass">{glassLabel} {item.glass}</span>}
    <span class="menu-item__price">{item.price}</span>
  </div>
</div>
