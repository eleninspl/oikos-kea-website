---
import { Image } from 'astro:assets';
import { useTranslations, getAlternateUrl, langBase } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { site } from '../lib/site';
import logoWordmark from '../assets/images/brand/logo-wordmark.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const path = Astro.url.pathname;
const alternateLang = lang === 'el' ? 'en' : 'el';
const alternateUrl = getAlternateUrl(path, alternateLang);

const base = langBase(lang);
const isActive = (page: string) => {
  if (page === '/') return path === '/' || path === '/en' || path === '/en/';
  return path.endsWith(page) || path.endsWith(page + '/');
};
---

<nav class="nav">
  <div class="nav__inner">
    <a href={base + '/'} class="nav__logo" aria-label={`${site.brand.name} Kea — ${t('nav.home')}`}>
      <Image src={logoWordmark} alt="" width={450} height={106} loading="eager" />
    </a>

    <ul class="nav__links">
      <li>
        <a href={base + '/'} class:list={['nav__link', { active: isActive('/') }]}
          >{t('nav.home')}</a
        >
      </li>
      <li>
        <a href={base + '/menu'} class:list={['nav__link', { active: isActive('/menu') }]}
          >{t('nav.menu')}</a
        >
      </li>
      <li>
        <a href={base + '/about'} class:list={['nav__link', { active: isActive('/about') }]}
          >{t('nav.about')}</a
        >
      </li>
      <li>
        <a href={base + '/contact'} class:list={['nav__link', { active: isActive('/contact') }]}
          >{t('nav.contact')}</a
        >
      </li>
      <li>
        <a
          href={alternateUrl}
          class="nav__lang"
          aria-label={`Switch to ${alternateLang === 'en' ? 'English' : 'Greek'}`}
        >
          {t('nav.lang')}
        </a>
      </li>
      <li><a href={`tel:${site.contact.phoneTel}`} class="nav__cta">{t('nav.reserve')}</a></li>
    </ul>

    <div class="nav__mobile-controls">
      <a
        href={alternateUrl}
        class="nav__lang nav__lang--burger"
        aria-label={`Switch to ${alternateLang === 'en' ? 'English' : 'Greek'}`}>{t('nav.lang')}</a
      >

      <button
        class="nav__burger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="nav__mobile" id="nav-mobile">
  <a href={base + '/'} class="nav__link">{t('nav.home')}</a>
  <a href={base + '/menu'} class="nav__link">{t('nav.menu')}</a>
  <a href={base + '/about'} class="nav__link">{t('nav.about')}</a>
  <a href={base + '/contact'} class="nav__link">{t('nav.contact')}</a>
  <a href={`tel:${site.contact.phoneTel}`} class="btn btn--outline" style="margin-top: 1rem;"
    >{t('nav.reserve')}</a
  >
</div>

<script>
  let savedScroll: number | null = null;

  // Πριν το swap: αποθήκευσε scroll αν πατήθηκε το lang button
  document.addEventListener('astro:before-preparation', (e: any) => {
    const from = new URL(e.from);
    const to = new URL(e.to);
    // Είναι αλλαγή γλώσσας αν το path αλλάζει μεταξύ /en/... και /...
    const isLangSwitch =
      (from.pathname.startsWith('/en') && !to.pathname.startsWith('/en')) ||
      (!from.pathname.startsWith('/en') && to.pathname.startsWith('/en'));
    if (isLangSwitch && !location.hash) {
      savedScroll = window.scrollY;
      e.scroll = 'preserve'; // πες στο Astro να μην κάνει scroll
    }
  });

  // Μετά το swap: επανέφερε scroll
  document.addEventListener('astro:after-swap', () => {
    if (savedScroll !== null) {
      window.scrollTo(0, savedScroll);
      savedScroll = null;
    }
    // Μετάφερε hash στη νέα γλώσσα (για μενού)
    if (location.hash) {
      document.querySelector(location.hash)?.scrollIntoView();
    }
  });
</script>

<style>
  /* ─── Nav ─── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    z-index: 100;
    transition:
      background-color var(--transition-slow),
      box-shadow var(--transition-slow);
  }

  /* .nav--scrolled προστίθεται από JS (BaseLayout) στο ίδιο <nav> element. */
  .nav--scrolled {
    background-color: rgb(from var(--brand-ink) r g b / 0.97);
    box-shadow: 0 1px 0 rgb(from var(--brand-accent) r g b / 0.15);
  }

  .nav__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    display: flex;
    align-items: center;
  }

  .nav__logo img {
    height: 26px;
    width: auto;
    display: block;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .nav__link {
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(from var(--brand-cream) r g b / 0.8);
    transition: color var(--transition-fast);
  }

  .nav__link:hover,
  .nav__link.active {
    color: var(--color-gold);
  }

  .nav__cta {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    border: 1px solid rgb(from var(--brand-accent) r g b / 0.4);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .nav__cta:hover {
    background-color: var(--color-gold);
    color: var(--color-dark);
    border-color: var(--color-gold);
  }

  .nav__lang {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgb(from var(--brand-cream) r g b / 0.55);
    border: 1px solid rgb(from var(--brand-cream) r g b / 0.18);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast);
  }
  .nav__lang:hover {
    color: var(--color-gold);
    border-color: rgb(from var(--brand-accent) r g b / 0.5);
  }

  .nav__mobile-controls {
    display: none;
    align-items: center;
    gap: var(--space-3);
  }

  .nav__lang--burger {
    display: none;
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
  }

  .nav__burger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background-color: var(--color-cream);
    transition:
      transform var(--transition-base),
      opacity var(--transition-base);
  }

  .nav__mobile {
    display: none;
    flex-direction: column;
    position: fixed;
    inset: 0;
    background-color: var(--color-dark);
    z-index: 99;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
  }

  /* .open προστίθεται από JS (BaseLayout) στο ίδιο element. */
  .nav__mobile.open {
    display: flex;
  }

  .nav__mobile .nav__link {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }
    .nav__mobile-controls {
      display: flex;
    }
    .nav__burger {
      display: flex;
    }
    .nav__lang--burger {
      display: inline-flex;
      align-items: center;
    }
  }
</style>
