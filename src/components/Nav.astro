---
import { useTranslations, getAlternateUrl, langBase } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { site } from '../lib/site';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const path = Astro.url.pathname;
const alternateLang = lang === 'el' ? 'en' : 'el';
const alternateUrl = getAlternateUrl(path, alternateLang);

const base = langBase(lang);
const isActive = (page: string) => {
  if (page === '/') return path === '/' || path === '/en' || path === '/en/';
  return path.endsWith(page) || path.endsWith(page + '/');
};
---

<nav class="nav">
  <div class="nav__inner">
    <a href={base + '/'} class="nav__logo" aria-label={`${site.brand.name} Kea — ${t('nav.home')}`}>
      <img src="/images/brand/logo-wordmark.png" alt="" width="450" height="106" />
    </a>

    <ul class="nav__links">
      <li>
        <a href={base + '/'} class:list={['nav__link', { active: isActive('/') }]}
          >{t('nav.home')}</a
        >
      </li>
      <li>
        <a href={base + '/menu'} class:list={['nav__link', { active: isActive('/menu') }]}
          >{t('nav.menu')}</a
        >
      </li>
      <li>
        <a href={base + '/about'} class:list={['nav__link', { active: isActive('/about') }]}
          >{t('nav.about')}</a
        >
      </li>
      <li>
        <a href={base + '/contact'} class:list={['nav__link', { active: isActive('/contact') }]}
          >{t('nav.contact')}</a
        >
      </li>
      <li>
        <a
          href={alternateUrl}
          class="nav__lang"
          aria-label={`Switch to ${alternateLang === 'en' ? 'English' : 'Greek'}`}
        >
          {t('nav.lang')}
        </a>
      </li>
      <li><a href={`tel:${site.contact.phoneTel}`} class="nav__cta">{t('nav.reserve')}</a></li>
    </ul>

    <div class="nav__mobile-controls">
      <a
        href={alternateUrl}
        class="nav__lang nav__lang--burger"
        aria-label={`Switch to ${alternateLang === 'en' ? 'English' : 'Greek'}`}>{t('nav.lang')}</a
      >

      <button
        class="nav__burger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="nav__mobile" id="nav-mobile">
  <a href={base + '/'} class="nav__link">{t('nav.home')}</a>
  <a href={base + '/menu'} class="nav__link">{t('nav.menu')}</a>
  <a href={base + '/about'} class="nav__link">{t('nav.about')}</a>
  <a href={base + '/contact'} class="nav__link">{t('nav.contact')}</a>
  <a href={`tel:${site.contact.phoneTel}`} class="btn btn--outline" style="margin-top: 1rem;"
    >{t('nav.reserve')}</a
  >
</div>

<script>
  // ── Διατήρηση θέσης scroll & ενεργής καρτέλας μενού κατά την αλλαγή γλώσσας ──
  // Η αλλαγή γλώσσας οδηγεί σε άλλο URL (full page load) που μηδενίζει το scroll.
  // Αποθηκεύουμε τη θέση πριν φύγουμε και την επαναφέρουμε στη νέα σελίδα.
  const KEY = 'oikosLangSwitch';

  document.querySelectorAll<HTMLAnchorElement>('.nav__lang').forEach((link) => {
    link.addEventListener('click', () => {
      // Μετάφερε την ανοιχτή κατηγορία μενού (hash) στη νέα γλώσσα
      if (location.hash) {
        const url = new URL(link.href, location.origin);
        url.hash = location.hash;
        link.href = url.toString();
      }
      // Κράτα τη θέση scroll για σελίδες χωρίς hash (αρχική, σχετικά, κ.λπ.)
      sessionStorage.setItem(KEY, JSON.stringify({ y: window.scrollY, hash: location.hash }));
    });
  });

  const raw = sessionStorage.getItem(KEY);
  if (raw) {
    sessionStorage.removeItem(KEY);
    try {
      const { y } = JSON.parse(raw) as { y: number };
      // Αν είμαστε σε λεπτομέρεια μενού (hash), το MenuPage κάνει το scroll·
      // αλλιώς επανέφερε τη θέση scroll όπως ήταν πριν την αλλαγή γλώσσας.
      if (!location.hash) requestAnimationFrame(() => window.scrollTo(0, y));
    } catch {}
  }
</script>
