---
import { useTranslations, getAlternateUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const path = Astro.url.pathname;
const alternateLang = lang === 'el' ? 'en' : 'el';
const alternateUrl = getAlternateUrl(path, alternateLang);

const base = lang === 'en' ? '/en' : '';
const isActive = (page: string) => {
  if (page === '/') return path === '/' || path === '/en' || path === '/en/';
  return path.endsWith(page) || path.endsWith(page + '/');
};
---

<nav class="nav">
  <div class="nav__inner">
    <a href={base + '/'} class="nav__logo">OIK<span>O</span>S</a>

    <ul class="nav__links">
      <li><a href={base + '/'} class:list={['nav__link', { active: isActive('/') }]}>{t('nav.home')}</a></li>
      <li><a href={base + '/menu'} class:list={['nav__link', { active: isActive('/menu') }]}>{t('nav.menu')}</a></li>
      <li><a href={base + '/about'} class:list={['nav__link', { active: isActive('/about') }]}>{t('nav.about')}</a></li>
      <li><a href={base + '/contact'} class:list={['nav__link', { active: isActive('/contact') }]}>{t('nav.contact')}</a></li>
      <li><a href="tel:+302288022507" class="nav__cta">{t('nav.reserve')}</a></li>
      <li>
        <a href={alternateUrl} class="nav__lang" aria-label={`Switch to ${alternateLang === 'en' ? 'English' : 'Greek'}`}>
          {t('nav.lang')}
        </a>
      </li>
    </ul>

    <button class="nav__burger" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<div class="nav__mobile">
  <a href={base + '/'} class="nav__link">{t('nav.home')}</a>
  <a href={base + '/menu'} class="nav__link">{t('nav.menu')}</a>
  <a href={base + '/about'} class="nav__link">{t('nav.about')}</a>
  <a href={base + '/contact'} class="nav__link">{t('nav.contact')}</a>
  <a href="tel:+302288022507" class="btn btn--outline" style="margin-top: 1rem;">{t('nav.reserve')}</a>
  <a href={alternateUrl} class="nav__lang" style="margin-top: var(--space-4);" aria-label={`Switch to ${alternateLang === 'en' ? 'English' : 'Greek'}`}>{t('nav.lang')}</a>
</div>

<script>
  // ── Διατήρηση θέσης scroll & ενεργής καρτέλας μενού κατά την αλλαγή γλώσσας ──
  // Η αλλαγή γλώσσας οδηγεί σε άλλο URL (full page load) που μηδενίζει το scroll.
  // Αποθηκεύουμε τη θέση πριν φύγουμε και την επαναφέρουμε στη νέα σελίδα.
  const KEY = 'oikosLangSwitch';

  document.querySelectorAll<HTMLAnchorElement>('.nav__lang').forEach((link) => {
    link.addEventListener('click', () => {
      const active = document.querySelector('.menu-tab-btn.active');
      sessionStorage.setItem(KEY, JSON.stringify({
        y: window.scrollY,
        panel: active?.getAttribute('data-panel') ?? null,
      }));
    });
  });

  const raw = sessionStorage.getItem(KEY);
  if (raw) {
    sessionStorage.removeItem(KEY);
    try {
      const { y, panel } = JSON.parse(raw) as { y: number; panel: string | null };
      if (panel) {
        const btn = document.querySelector(`.menu-tab-btn[data-panel="${panel}"]`);
        const target = document.getElementById(panel);
        if (btn && target) {
          document.querySelectorAll('.menu-tab-btn').forEach((b) => {
            b.classList.remove('active');
            b.setAttribute('aria-selected', 'false');
          });
          document.querySelectorAll('.menu-panel').forEach((p) => p.classList.remove('active'));
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
          target.classList.add('active');
        }
      }
      requestAnimationFrame(() => window.scrollTo(0, y));
    } catch {}
  }
</script>
