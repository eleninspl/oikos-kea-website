---
import { Picture } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../PageHero.astro';
import CtaBanner from '../CtaBanner.astro';
import { useTranslations, langBase } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { mapsDirectionsUrl } from '../../lib/site';
import signImg from '../../assets/images/brand/sign.jpg';
import chefsImg from '../../assets/images/chefs-kitchen-bw.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = langBase(lang);
---

<BaseLayout title={t('about.seo.title')} description={t('about.seo.desc')} lang={lang}>
  <PageHero eyebrow={t('about.eyebrow')} title={t('about.title')} subtitle={t('about.subtitle')} />

  <!-- Who we are -->
  <section class="section section--cream">
    <div class="container">
      <div class="split">
        <div>
          <p class="eyebrow">{t('about.who.eyebrow')}</p>
          <div class="divider"></div>
          <h2 class="section-title" style="margin-bottom:var(--space-6);">
            <em>{t('about.who.title')}</em>
          </h2>
          <p class="body-text" style="margin-bottom:var(--space-6);">
            {t('about.who.text1')}
          </p>
          <p class="body-text">
            {t('about.who.text2')}
          </p>
        </div>
        <div style="overflow:hidden; border-radius:var(--radius-md);">
          <Picture
            src={signImg}
            formats={['avif', 'webp']}
            fallbackFormat="jpeg"
            alt="The OIKOS sign on a marble wall with guests at the entrance"
            widths={[640, 960, 1280]}
            sizes="(max-width: 900px) 100vw, 50vw"
            style="width:100%; height:500px; object-fit:cover;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section--dark section--centered">
    <div class="container">
      <div class="about-stat-row">
        <div>
          <span class="about-stat__number">2021</span>
          <div class="about-stat__label">{t('about.stat1.label')}</div>
        </div>
        <div>
          <span class="about-stat__number">{t('about.stat2.val')}</span>
          <div class="about-stat__label">{t('about.stat2.label')}</div>
        </div>
        <div>
          <span class="about-stat__number">{t('about.stat3.val')}</span>
          <div class="about-stat__label">{t('about.stat3.label')}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="section section--cream-alt">
    <div class="container">
      <div class="split split--reverse">
        <div style="overflow:hidden; border-radius:var(--radius-md);">
          <video
            src="/images/brand/all-day.mp4"
            autoplay
            muted
            loop
            playsinline
            style="width:100%; height:500px; object-fit:cover;"></video>
        </div>
        <div>
          <p class="eyebrow">{t('about.phil.eyebrow')}</p>
          <div class="divider"></div>
          <h2 class="section-title" style="margin-bottom:var(--space-6);">
            {t('about.phil.title1')}<br />{t('about.phil.title2')}
          </h2>
          <p class="body-text" style="margin-bottom:var(--space-6);">
            {t('about.phil.text1')}
          </p>
          <p class="body-text">
            {t('about.phil.text2')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our kitchen -->
  <section class="section section--cream">
    <div class="container">
      <div class="split">
        <div style="overflow:hidden; border-radius:var(--radius-md);">
          <Picture
            src={chefsImg}
            formats={['avif', 'webp']}
            fallbackFormat="jpeg"
            alt="Two chefs in the OIKOS kitchen"
            widths={[640, 960, 1280]}
            sizes="(max-width: 900px) 100vw, 50vw"
            style="width:100%; height:auto; display:block;"
            loading="lazy"
          />
        </div>
        <div>
          <p class="eyebrow">{t('about.kitchen.eyebrow')}</p>
          <div class="divider"></div>
          <h2 class="section-title" style="margin-bottom:var(--space-6);">
            {t('about.kitchen.title')}
          </h2>
          <p class="body-text" style="margin-bottom:var(--space-6);">
            {t('about.kitchen.text1')}
          </p>
          <p class="body-text">
            {t('about.kitchen.text2')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner title={t('about.cta.title')} subtitle={t('about.cta.subtitle')}>
    <div class="cta-actions">
      <a href={mapsDirectionsUrl} target="_blank" rel="noopener noreferrer" class="btn btn--dark"
        >{t('about.cta.dir')}</a
      >
      <a href={base + '/menu'} class="btn btn--outline">{t('about.cta.menu')}</a>
    </div>
  </CtaBanner>
</BaseLayout>

<style>
  /* ─── About page — stats row ─── */
  .about-stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  .about-stat__number {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    color: var(--color-gold);
    display: block;
  }

  .about-stat__label {
    font-size: var(--text-sm);
    color: rgb(from var(--brand-cream) r g b / 0.65);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: var(--space-2);
  }

  @media (max-width: 640px) {
    .about-stat-row {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
