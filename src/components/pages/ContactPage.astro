---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../PageHero.astro';
import CtaBanner from '../CtaBanner.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { site } from '../../lib/site';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const days = [
  t('contact.hours.mon'),
  t('contact.hours.tue'),
  t('contact.hours.wed'),
  t('contact.hours.thu'),
  t('contact.hours.fri'),
  t('contact.hours.sat'),
  t('contact.hours.sun'),
];
---

<BaseLayout title={t('contact.seo.title')} description={t('contact.seo.desc')} lang={lang}>
  <PageHero eyebrow={t('contact.eyebrow')} title={t('contact.title')} subtitle={t('contact.subtitle')} />

  <section class="section section--cream">
    <div class="container">
      <div class="contact-grid">
        <div>
          <div class="info-block">
            <div class="info-block__label">{t('contact.address.label')}</div>
            <div class="info-block__value">{t('contact.address.val')}</div>
            <div class="info-block__sub">{t('contact.address.sub')}</div>
          </div>

          <div class="info-block">
            <div class="info-block__label">{t('contact.phone.label')}</div>
            <a href={`tel:${site.phoneTel}`} class="info-block__value" style="color:var(--color-gold-dim);">
              {site.phoneDisplay}
            </a>
            <div class="info-block__sub">{t('contact.phone.sub')}</div>
          </div>

          <div class="info-block">
            <div class="info-block__label">{t('contact.email.label')}</div>
            <a href={`mailto:${site.email}`} class="info-block__value" style="color:var(--color-gold-dim); font-size:var(--text-lg);">
              {site.email}
            </a>
          </div>

          <div class="info-block">
            <div class="info-block__label">{t('contact.ig.label')}</div>
            <a
              href={site.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="info-block__value"
              style="color:var(--color-gold-dim); font-size:var(--text-lg);"
            >
              @oikos_kea
            </a>
          </div>

          <div class="divider" style="margin-top:var(--space-10);"></div>

          <div class="info-block__label" style="margin-bottom:var(--space-4);">{t('contact.hours.label')}</div>
          <table class="hours-table">
            <tbody>
              {days.map((day) => (
                <tr>
                  <td>{day}</td>
                  <td>09:00 – 02:00</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div>
          <iframe
            class="map-embed"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3158.1!2d24.33!3d37.64!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14a1b2c3d4e5f6a7%3A0x0!2sKorrisia%2C+K%C3%A9a%2C+Greece!5e0!3m2!1sen!2sgr!4v1234567890"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="OIKOS location in Korrisia, Kéa"
          ></iframe>

          <div style="margin-top:var(--space-8); padding:var(--space-8); background:var(--color-cream-alt); border-radius:var(--radius-md);">
            <p class="eyebrow" style="margin-bottom:var(--space-3);">{t('contact.here.label')}</p>
            <p style="font-size:var(--text-sm); color:var(--text-muted); line-height:1.8;">
              {t('contact.here.text')}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner title={t('contact.cta.title')} subtitle={t('contact.cta.subtitle')}>
    <a href={`tel:${site.phoneTel}`} class="btn btn--dark">{t('contact.cta.btn')}</a>
  </CtaBanner>
</BaseLayout>
