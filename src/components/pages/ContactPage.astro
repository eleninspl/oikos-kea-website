---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../PageHero.astro';
import CtaBanner from '../CtaBanner.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { site } from '../../lib/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const days = [
  t('contact.hours.mon'),
  t('contact.hours.tue'),
  t('contact.hours.wed'),
  t('contact.hours.thu'),
  t('contact.hours.fri'),
  t('contact.hours.sat'),
  t('contact.hours.sun'),
];
---

<BaseLayout title={t('contact.seo.title')} description={t('contact.seo.desc')} lang={lang}>
  <PageHero
    eyebrow={t('contact.eyebrow')}
    title={t('contact.title')}
    subtitle={t('contact.subtitle')}
  />

  <section class="section section--cream">
    <div class="container">
      <div class="contact-grid">
        <div>
          <div class="info-block">
            <div class="info-block__label">{t('contact.address.label')}</div>
            <a
              href={site.social.googleMaps}
              target="_blank"
              rel="noopener noreferrer"
              class="info-block__value"
              style="color:var(--color-gold-dim);">{t('contact.address.val')}</a
            >
            <div class="info-block__sub">{t('contact.address.sub')}</div>
          </div>

          <div class="info-block">
            <div class="info-block__label">{t('contact.phone.label')}</div>
            <a
              href={`tel:${site.contact.phoneTel}`}
              class="info-block__value"
              style="color:var(--color-gold-dim);"
            >
              {site.contact.phoneDisplay}
            </a>
            <div class="info-block__sub">{t('contact.phone.sub')}</div>
          </div>

          <div class="info-block">
            <div class="info-block__label">{t('contact.email.label')}</div>
            <a
              href={`mailto:${site.contact.email}`}
              class="info-block__value"
              style="color:var(--color-gold-dim); font-size:var(--text-lg);"
            >
              {site.contact.email}
            </a>
          </div>

          <div class="info-block">
            <div class="info-block__label">{t('contact.ig.label')}</div>
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="info-block__value"
              style="color:var(--color-gold-dim); font-size:var(--text-lg);"
            >
              {site.social.instagramHandle}
            </a>
          </div>

          <div class="divider" style="margin-top:var(--space-10);"></div>

          <div class="info-block__label" style="margin-bottom:var(--space-4);">
            {t('contact.hours.label')}
          </div>
          <table class="hours-table">
            <tbody>
              {
                days.map((day) => (
                  <tr>
                    <td>{day}</td>
                    <td>{site.hours.display}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <div>
          <iframe
            class="map-embed"
            src={site.social.googleMapsEmbed}
            width="100%"
            height="450"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            title={`${site.brand.name} location in ${site.address.areaEn}, ${site.address.cityEn}`}
          ></iframe>

          <div
            style="margin-top:var(--space-8); padding:var(--space-8); background:var(--color-cream-alt); border-radius:var(--radius-md);"
          >
            <p class="eyebrow" style="margin-bottom:var(--space-3);">{t('contact.here.label')}</p>
            <p style="font-size:var(--text-sm); color:var(--text-muted); line-height:1.8;">
              {t('contact.here.text')}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner title={t('contact.cta.title')} subtitle={t('contact.cta.subtitle')}>
    <a href={`tel:${site.contact.phoneTel}`} class="btn btn--dark">{t('contact.cta.btn')}</a>
  </CtaBanner>
</BaseLayout>

<style>
  /* ─── Contact page ─── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
  }

  .info-block {
    margin-bottom: var(--space-8);
  }

  .info-block__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-2);
  }

  .info-block__value {
    font-size: var(--text-xl);
    font-family: var(--font-heading);
    color: var(--text-dark);
  }

  .info-block__sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: var(--space-1);
  }

  .hours-table {
    width: 100%;
    border-collapse: collapse;
  }

  .hours-table tr {
    border-bottom: 1px solid rgb(from var(--brand-ink) r g b / 0.08);
  }

  .hours-table td {
    padding: var(--space-3) 0;
    font-size: var(--text-sm);
  }

  .hours-table td:last-child {
    text-align: right;
    color: var(--text-muted);
  }

  .map-embed {
    width: 100%;
    height: 400px;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: none;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
