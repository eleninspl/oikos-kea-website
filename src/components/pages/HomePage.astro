---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../CtaBanner.astro';
import { useTranslations, langBase } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { site } from '../../lib/site';
import signImg from '../../assets/images/brand/sign.jpg';
import sushiRollsImg from '../../assets/images/sushi-rolls-cocktail.jpg';
import bartenderImg from '../../assets/images/bartender-cocktail-mint.jpg';
import reservedTableImg from '../../assets/images/reserved-table-night.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = langBase(lang);
---

<BaseLayout title={t('home.seo.title')} description={t('home.seo.desc')} lang={lang}>
  <!-- Hero -->
  <section class="hero">
    <video
      class="hero__bg"
      src="/images/brand/hero.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="none"></video>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__eyebrow">{t('hero.eyebrow')}</p>
      <h1 class="hero__title">
        {t('hero.title1')}<br /><em>{t('hero.title2')}</em>
      </h1>
      <p class="hero__subtitle">{t('hero.subtitle')}</p>
      <div class="hero__actions">
        <a href={base + '/menu'} class="btn btn--gold">{t('hero.cta1')}</a>
        <a href={base + '/contact'} class="btn btn--outline-light">{t('hero.cta2')}</a>
      </div>
    </div>
    <div class="hero__scroll">
      <div class="hero__scroll-line"></div>
      <span>{t('hero.scroll')}</span>
    </div>
  </section>

  <!-- About strip -->
  <section class="about-strip">
    <div class="about-strip__image">
      <!-- TODO: replace src with harbor/sea photo of Korrisia when available -->
      <Image
        src={signImg}
        alt="The OIKOS sign on a marble wall with guests in the foreground"
        widths={[640, 960, 1280]}
        sizes="(max-width: 900px) 100vw, 50vw"
        loading="lazy"
      />
    </div>
    <div class="about-strip__content">
      <p class="eyebrow">{t('home.about.eyebrow')}</p>
      <div class="divider"></div>
      <h2 class="section-title">
        {t('home.about.title1')}<br />{t('home.about.title2')}
      </h2>
      <p>{t('home.about.text')}</p>
      <a href={base + '/about'} class="btn btn--outline">{t('home.about.cta')}</a>
    </div>
  </section>

  <!-- Services -->
  <section style="padding-bottom: var(--space-16);">
    <div class="services">
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/pancakes-berries-coffee.jpg"
            alt="Pancakes with strawberries, blueberries and a latte at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Brunch</h3>
          <p class="service-card__desc">{t('svc.brunch.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <Image
            src={sushiRollsImg}
            alt="Sushi rolls with a cocktail at OIKOS"
            widths={[480, 768, 1067]}
            sizes="(max-width: 900px) 50vw, 25vw"
            loading="lazy"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Sushi</h3>
          <p class="service-card__desc">{t('svc.sushi.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/food/risotto.jpg"
            alt="Risotto dish at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Lunch &amp; Dinner</h3>
          <p class="service-card__desc">{t('svc.lunch.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/drinks/cocktail.jpg"
            alt="Craft cocktail with bitters at the OIKOS bar"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Cocktails</h3>
          <p class="service-card__desc">{t('svc.cocktails.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Events -->
  <section class="section section--dark section--centered">
    <div class="container--narrow">
      <p class="eyebrow">{t('home.events.eyebrow')}</p>
      <div class="divider divider--centered"></div>
      <h2 class="section-title" style="margin-bottom:var(--space-6);">
        {t('home.events.title').split('\n')[0]}<br />
        <em>{t('home.events.title').split('\n')[1]}</em>
      </h2>
      <p
        class="body-text"
        style="margin-bottom:var(--space-8); max-width:520px; margin-inline:auto;"
      >
        {t('home.events.text')}
      </p>
      <a href={base + '/contact'} class="btn btn--gold">{t('home.events.cta')}</a>
    </div>
  </section>

  <!-- Bar -->
  <section class="section section--cream-alt">
    <div class="container">
      <div class="split split--reverse split--side-mobile">
        <div>
          <p class="eyebrow">{t('home.bar.eyebrow')}</p>
          <div class="divider"></div>
          <h2 class="section-title" style="margin-bottom:var(--space-6);">
            {
              t('home.bar.title')
                .split('\n')
                .map((line, i) =>
                  i === 0 ? (
                    line
                  ) : (
                    <>
                      <>
                        <br />
                        <em>{line}</em>
                      </>
                    </>
                  ),
                )
            }
          </h2>
          <p class="body-text">{t('home.bar.text')}</p>
        </div>
        <div style="overflow:hidden; border-radius:var(--radius-md);">
          <Image
            src={bartenderImg}
            alt="Bartender preparing a cocktail with crushed ice and mint at OIKOS"
            class="bar-img"
            widths={[640, 960, 1067]}
            sizes="(max-width: 900px) 100vw, 50vw"
            style="width:100%; height:500px; object-fit:cover; object-position:center 30%; display:block;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Food marquee -->
  <section class="food-marquee-section">
    <div class="food-marquee" aria-hidden="true">
      <div class="food-marquee__track">
        {
          [
            { src: '/images/food/hamachi-jalapeno.jpg', alt: 'Hamachi jalapeño sushi at OIKOS' },
            {
              src: '/images/pasta-tagliatelle-table.jpg',
              alt: 'Tagliatelle on the table at OIKOS',
            },
            {
              src: '/images/aburi-nigiri-rose-wine.jpg',
              alt: 'Aburi nigiri with rosé wine at OIKOS',
            },
            {
              src: '/images/pancakes-berries-coffee.jpg',
              alt: 'Pancakes with berries and coffee at OIKOS',
            },
            { src: '/images/food/spicy-maguro.webp', alt: 'Spicy maguro sushi at OIKOS' },
            { src: '/images/food/donburi.webp', alt: 'Donburi bowl at OIKOS' },
            // duplicated for seamless loop
            { src: '/images/food/hamachi-jalapeno.jpg', alt: 'Hamachi jalapeño sushi at OIKOS' },
            {
              src: '/images/pasta-tagliatelle-table.jpg',
              alt: 'Tagliatelle on the table at OIKOS',
            },
            {
              src: '/images/aburi-nigiri-rose-wine.jpg',
              alt: 'Aburi nigiri with rosé wine at OIKOS',
            },
            {
              src: '/images/pancakes-berries-coffee.jpg',
              alt: 'Pancakes with berries and coffee at OIKOS',
            },
            { src: '/images/food/spicy-maguro.webp', alt: 'Spicy maguro sushi at OIKOS' },
            { src: '/images/food/donburi.webp', alt: 'Donburi bowl at OIKOS' },
          ].map(({ src, alt }) => (
            <div class="food-marquee__item">
              <img src={src} alt={alt} loading="lazy" decoding="async" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section section--dark">
    <div class="container">
      <div class="container--narrow">
        <p class="eyebrow">{t('reviews.eyebrow')}</p>
        <div class="divider divider--centered"></div>
        <h2 class="section-title">
          {t('reviews.title1')}<br />{t('reviews.title2')}
        </h2>
        <a
          href={site.social.googleReviews}
          target="_blank"
          rel="noopener noreferrer"
          class="google-rating"
        >
          <span class="google-rating__score">{site.social.googleRating.value}</span>
          <span class="google-rating__stars" aria-label="5 out of 5 stars" role="img">★★★★★</span>
          <span class="google-rating__count"
            >{site.social.googleRating.count} {t('reviews.google')}</span
          >
        </a>
      </div>

      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "All the food we tasted was delicious. With the coffee and shakes, it was amazing… I
            definitely recommend it."
          </p>
          <span class="review-card__author">Stano Bagin · {t('reviews.guide')}</span>
        </div>
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "Food was delicious ✨ wine was also good. The lemon pie is enormous — share it with
            three people! I really recommend the salmon with couscous."
          </p>
          <span class="review-card__author">Anys Hruba · {t('reviews.guide')}</span>
        </div>
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "The food here is absolutely amazing. We came for breakfast 3 times and for lunch 1 time
            and everything was perfect. So tasty and the service amazing. Recommend for everyone."
          </p>
          <span class="review-card__author">Petros Isaias · {t('reviews.guide')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Ambiance -->
  <section
    style="position:relative; min-height:480px; display:flex; align-items:center; justify-content:center; overflow:hidden;"
  >
    <Image
      src={reservedTableImg}
      alt="A reserved table at OIKOS at night"
      widths={[640, 1024, 1600]}
      sizes="100vw"
      style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;"
      loading="lazy"
    />
    <div style="position:absolute; inset:0; background:rgba(0,0,0,0.35);"></div>
    <div
      style="position:relative; text-align:center; color:#fff; padding:var(--space-16) var(--space-8); max-width:600px;"
    >
      <h2 class="section-title" style="color:#fff; margin-bottom:var(--space-4);">
        {t('home.ambiance.title')}
      </h2>
      <p
        style="font-size:var(--text-sm); letter-spacing:0.12em; text-transform:uppercase; opacity:0.75; margin-bottom:var(--space-8);"
      >
        {t('home.ambiance.sub')}
      </p>
      <a href={`tel:${site.contact.phoneTel}`} class="btn btn--outline-light">{t('cta.call')}</a>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner title={t('cta.title')} subtitle={t('cta.subtitle')}>
    <div class="cta-actions">
      <a href={base + '/menu'} class="btn btn--dark">{t('cta.menu')}</a>
    </div>
  </CtaBanner>

  <!-- Info strip -->
  <section class="section section--mid section--centered" style="padding-block: var(--space-16);">
    <div class="container">
      <div class="info-strip">
        <div>
          <p class="eyebrow">{t('info.location.label')}</p>
          <a
            href={site.social.googleMaps}
            target="_blank"
            rel="noopener noreferrer"
            class="info-strip__val"
            style="color:inherit;">{t('info.location.val')}</a
          >
          <p class="info-strip__sub">{t('info.location.sub')}</p>
        </div>
        <div>
          <p class="eyebrow">{t('info.hours.label')}</p>
          <p class="info-strip__val">{t('info.hours.val')}</p>
          <p class="info-strip__sub">{t('info.hours.sub')}</p>
        </div>
        <div>
          <p class="eyebrow">{t('info.res.label')}</p>
          <p class="info-strip__val">{site.contact.phoneDisplay}</p>
          <p class="info-strip__sub">{t('info.res.sub')}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-dark);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    object-fit: cover;
    width: 100%;
    height: 100%;
    opacity: 0.45;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgb(from var(--brand-ink) r g b / 0.3) 0%,
      rgb(from var(--brand-ink) r g b / 0.1) 40%,
      rgb(from var(--brand-ink) r g b / 0.7) 100%
    );
  }

  .hero__content {
    position: relative;
    text-align: center;
    color: var(--text-light);
    padding-inline: var(--space-8);
    max-width: 800px;
  }

  .hero__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-6);
  }

  .hero__title {
    font-size: clamp(var(--text-4xl), 8vw, 6rem);
    font-family: var(--font-heading);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: var(--space-6);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: rgb(from var(--brand-cream) r g b / 0.8);
    margin-bottom: var(--space-10);
    letter-spacing: 0.02em;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: rgb(from var(--brand-cream) r g b / 0.5);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgb(from var(--brand-accent) r g b / 0.8), transparent);
  }

  /* ─── About strip ─── */
  .about-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    height: 860px;
    margin-top: 0;
  }

  .about-strip__image {
    position: relative;
    overflow: hidden;
  }

  .about-strip__image img,
  .about-strip__image video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .about-strip__image:hover img,
  .about-strip__image:hover video {
    transform: scale(1.03);
  }

  .about-strip__content {
    background-color: var(--color-mid);
    color: var(--text-light);
    padding: var(--space-16) var(--space-12);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-strip__content .section-title {
    color: var(--color-cream);
    margin-bottom: var(--space-6);
  }

  .about-strip__content p {
    color: rgb(from var(--brand-cream) r g b / 0.75);
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: 1.8;
    margin-bottom: var(--space-8);
  }

  /* ─── Services grid ─── */
  .services {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background-color: rgb(from var(--brand-ink) r g b / 0.1);
    margin-top: var(--space-16);
  }

  .service-card {
    background-color: var(--color-cream);
    overflow: hidden;
    transition: background-color var(--transition-base);
  }

  .service-card:hover {
    background-color: var(--color-cream-alt);
  }

  .service-card__media {
    width: 100%;
    height: 300px;
    overflow: hidden;
  }

  .service-card__media img,
  .service-card__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
    display: block;
  }

  .service-card:hover .service-card__media img,
  .service-card:hover .service-card__media video {
    transform: scale(1.04);
  }

  .service-card__body {
    padding: var(--space-8) var(--space-8);
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: var(--space-3);
  }

  .service-card__desc {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ─── Reviews ─── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-12);
  }

  .review-card {
    background-color: rgb(from var(--brand-cream) r g b / 0.05);
    border: 1px solid rgb(from var(--brand-accent) r g b / 0.15);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }

  .review-card__stars {
    color: var(--color-star);
    font-size: var(--text-sm);
    letter-spacing: 2px;
    margin-bottom: var(--space-4);
  }

  .review-card__text {
    font-size: var(--text-base);
    line-height: 1.75;
    color: rgb(from var(--brand-cream) r g b / 0.8);
    font-style: italic;
    margin-bottom: var(--space-6);
  }

  .review-card__author {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  /* ─── Gallery mosaic ─── */
  .gallery-mosaic {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 280px);
    gap: var(--space-2);
  }

  .gallery-mosaic__item {
    overflow: hidden;
    position: relative;
  }

  .gallery-mosaic__item:first-child {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery-mosaic__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .gallery-mosaic__item:hover img {
    transform: scale(1.05);
  }

  .gallery-mosaic__item--placeholder {
    background-color: var(--color-mid);
  }

  /* ─── Google rating badge ─── */
  .google-rating {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding: var(--space-3) var(--space-6);
    border: 1px solid rgb(from var(--brand-accent) r g b / 0.25);
    border-radius: var(--radius-full);
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .google-rating:hover {
    border-color: rgb(from var(--brand-accent) r g b / 0.5);
    background-color: rgb(from var(--brand-accent) r g b / 0.06);
  }

  .google-rating__score {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-cream);
    line-height: 1;
  }

  .google-rating__stars {
    color: var(--color-star);
    font-size: var(--text-sm);
    letter-spacing: 2px;
  }

  .google-rating__count {
    font-size: var(--text-sm);
    color: rgb(from var(--brand-cream) r g b / 0.55);
    letter-spacing: 0.06em;
  }

  /* ─── Info strip ─── */
  .info-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    max-width: 800px;
    margin-inline: auto;
  }

  .info-strip__val {
    color: var(--text-light);
    margin-top: var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--text-xl);
  }

  .info-strip__sub {
    color: rgb(from var(--brand-cream) r g b / 0.55);
    font-size: var(--text-sm);
  }

  /* ── Food marquee ── */
  .food-marquee-section {
    padding-block: var(--space-12);
    background: var(--brand-cream);
    overflow: hidden;
  }

  .food-marquee {
    overflow: hidden;
    width: 100%;
    cursor: default;
  }

  .food-marquee__track {
    display: flex;
    gap: var(--space-4);
    width: max-content;
    animation: marquee-scroll 32s linear infinite;
  }

  .food-marquee:hover .food-marquee__track {
    animation-play-state: paused;
  }

  .food-marquee__item {
    width: 260px;
    height: 340px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .food-marquee__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .food-marquee:hover .food-marquee__item img {
    transform: scale(1.04);
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .about-strip {
      grid-template-columns: 1fr;
      height: auto;
    }

    .about-strip__image {
      height: 320px;
    }

    .services {
      grid-template-columns: repeat(2, 1fr);
    }

    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .gallery-mosaic {
      grid-template-columns: repeat(2, 1fr);
