---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../CtaBanner.astro';
import { useTranslations, langBase } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { site } from '../../lib/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = langBase(lang);
---

<BaseLayout title={t('home.seo.title')} description={t('home.seo.desc')} lang={lang}>
  <!-- Hero -->
  <section class="hero">
    <video class="hero__bg" src="/images/brand/hero.mp4" autoplay muted loop playsinline></video>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__eyebrow">{t('hero.eyebrow')}</p>
      <h1 class="hero__title">
        {t('hero.title1')}<br /><em>{t('hero.title2')}</em>
      </h1>
      <p class="hero__subtitle">{t('hero.subtitle')}</p>
      <div class="hero__actions">
        <a href={base + '/menu'} class="btn btn--gold">{t('hero.cta1')}</a>
        <a href={base + '/contact'} class="btn btn--outline-light">{t('hero.cta2')}</a>
      </div>
    </div>
    <div class="hero__scroll">
      <div class="hero__scroll-line"></div>
      <span>{t('hero.scroll')}</span>
    </div>
  </section>

  <!-- About strip -->
  <section class="about-strip">
    <div class="about-strip__image">
      <!-- TODO: replace src with harbor/sea photo of Korrisia when available -->
      <img
        src="/images/brand/sign.jpg"
        alt="The OIKOS sign on a marble wall with guests in the foreground"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="about-strip__content">
      <p class="eyebrow">{t('home.about.eyebrow')}</p>
      <div class="divider"></div>
      <h2 class="section-title">
        {t('home.about.title1')}<br />{t('home.about.title2')}
      </h2>
      <p>{t('home.about.text')}</p>
      <a href={base + '/about'} class="btn btn--outline">{t('home.about.cta')}</a>
    </div>
  </section>

  <!-- Services -->
  <section style="padding-bottom: var(--space-16);">
    <div class="services">
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/pancakes-berries-coffee.jpg"
            alt="Pancakes with strawberries, blueberries and a latte at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Brunch</h3>
          <p class="service-card__desc">{t('svc.brunch.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/sushi-rolls-cocktail.jpg"
            alt="Sushi rolls with a cocktail at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Sushi</h3>
          <p class="service-card__desc">{t('svc.sushi.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/food/risotto.jpg"
            alt="Risotto dish at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Lunch &amp; Dinner</h3>
          <p class="service-card__desc">{t('svc.lunch.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/drinks/cocktail.jpg"
            alt="Craft cocktail with bitters at the OIKOS bar"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Cocktails</h3>
          <p class="service-card__desc">{t('svc.cocktails.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Events -->
  <section class="section section--dark section--centered">
    <div class="container--narrow">
      <p class="eyebrow">{t('home.events.eyebrow')}</p>
      <div class="divider divider--centered"></div>
      <h2 class="section-title" style="margin-bottom:var(--space-6);">
        {t('home.events.title').split('\n')[0]}<br />
        <em>{t('home.events.title').split('\n')[1]}</em>
      </h2>
      <p class="body-text" style="margin-bottom:var(--space-8); max-width:520px; margin-inline:auto;">
        {t('home.events.text')}
      </p>
      <a href={base + '/contact'} class="btn btn--gold">{t('home.events.cta')}</a>
    </div>
  </section>

  <!-- Bar -->
  <section class="section section--cream-alt">
    <div class="container">
      <div class="about-content about-content--reverse about-content--side-mobile">
        <div>
          <p class="eyebrow">{t('home.bar.eyebrow')}</p>
          <div class="divider"></div>
          <h2 class="section-title" style="margin-bottom:var(--space-6);">
            {t('home.bar.title').split('\n').map((line, i) => i === 0 ? line : <><br /><em>{line}</em></>)}
          </h2>
          <p class="body-text">{t('home.bar.text')}</p>
        </div>
        <div style="overflow:hidden; border-radius:var(--radius-md);">
          <img
            src="/images/bartender-cocktail-mint.jpg"
            alt="Bartender preparing a cocktail with crushed ice and mint at OIKOS"
            class="bar-img"
            style="width:100%; height:500px; object-fit:cover; object-position:center 30%; display:block;"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Food marquee -->
  <section class="food-marquee-section">
    <div class="food-marquee" aria-hidden="true">
      <div class="food-marquee__track">
        {[
          { src: '/images/food/hamachi-jalapeno.jpg',      alt: 'Hamachi jalapeño sushi at OIKOS' },
          { src: '/images/pasta-tagliatelle-table.jpg',    alt: 'Tagliatelle on the table at OIKOS' },
          { src: '/images/aburi-nigiri-rose-wine.jpg',     alt: 'Aburi nigiri with rosé wine at OIKOS' },
          { src: '/images/pancakes-berries-coffee.jpg',    alt: 'Pancakes with berries and coffee at OIKOS' },
          { src: '/images/food/spicy-maguro.webp',         alt: 'Spicy maguro sushi at OIKOS' },
          { src: '/images/food/donburi.webp',              alt: 'Donburi bowl at OIKOS' },
          // duplicated for seamless loop
          { src: '/images/food/hamachi-jalapeno.jpg',      alt: 'Hamachi jalapeño sushi at OIKOS' },
          { src: '/images/pasta-tagliatelle-table.jpg',    alt: 'Tagliatelle on the table at OIKOS' },
          { src: '/images/aburi-nigiri-rose-wine.jpg',     alt: 'Aburi nigiri with rosé wine at OIKOS' },
          { src: '/images/pancakes-berries-coffee.jpg',    alt: 'Pancakes with berries and coffee at OIKOS' },
          { src: '/images/food/spicy-maguro.webp',         alt: 'Spicy maguro sushi at OIKOS' },
          { src: '/images/food/donburi.webp',              alt: 'Donburi bowl at OIKOS' },
        ].map(({ src, alt }) => (
          <div class="food-marquee__item">
            <img src={src} alt={alt} loading="lazy" decoding="async" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section section--dark">
    <div class="container">
      <div class="container--narrow">
        <p class="eyebrow">{t('reviews.eyebrow')}</p>
        <div class="divider divider--centered"></div>
        <h2 class="section-title">
          {t('reviews.title1')}<br />{t('reviews.title2')}
        </h2>
        <a
          href={site.social.googleReviews}
          target="_blank"
          rel="noopener noreferrer"
          class="google-rating"
        >
          <span class="google-rating__score">{site.social.googleRating.value}</span>
          <span class="google-rating__stars" aria-label="5 out of 5 stars" role="img">★★★★★</span>
          <span class="google-rating__count"
            >{site.social.googleRating.count} {t('reviews.google')}</span
          >
        </a>
      </div>

      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "All the food we tasted was delicious. With the coffee and shakes, it was amazing… I
            definitely recommend it."
          </p>
          <span class="review-card__author">Stano Bagin · {t('reviews.guide')}</span>
        </div>
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "Food was delicious ✨ wine was also good. The lemon pie is enormous — share it with
            three people! I really recommend the salmon with couscous."
          </p>
          <span class="review-card__author">Anys Hruba · {t('reviews.guide')}</span>
        </div>
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "The food here is absolutely amazing. We came for breakfast 3 times and for lunch 1 time
            and everything was perfect. So tasty and the service amazing. Recommend for everyone."
          </p>
          <span class="review-card__author">Petros Isaias · {t('reviews.guide')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Ambiance -->
  <section style="position:relative; min-height:480px; display:flex; align-items:center; justify-content:center; overflow:hidden;">
    <img
      src="/images/reserved-table-night.jpg"
      alt="A reserved table at OIKOS at night"
      style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;"
      loading="lazy"
      decoding="async"
    />
    <div style="position:absolute; inset:0; background:rgba(0,0,0,0.35);"></div>
    <div style="position:relative; text-align:center; color:#fff; padding:var(--space-16) var(--space-8); max-width:600px;">
      <h2 class="section-title" style="color:#fff; margin-bottom:var(--space-4);">
        {t('home.ambiance.title')}
      </h2>
      <p style="font-size:var(--text-sm); letter-spacing:0.12em; text-transform:uppercase; opacity:0.75; margin-bottom:var(--space-8);">
        {t('home.ambiance.sub')}
      </p>
      <a href={`tel:${site.contact.phoneTel}`} class="btn btn--outline-light">{t('cta.call')}</a>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner title={t('cta.title')} subtitle={t('cta.subtitle')}>
    <div class="cta-actions">
      <a href={base + '/menu'} class="btn btn--dark">{t('cta.menu')}</a>
    </div>
  </CtaBanner>

  <!-- Info strip -->
  <section class="section section--mid section--centered" style="padding-block: var(--space-16);">
    <div class="container">
      <div class="info-strip">
        <div>
          <p class="eyebrow">{t('info.location.label')}</p>
          <a
            href={site.social.googleMaps}
            target="_blank"
            rel="noopener noreferrer"
            class="info-strip__val"
            style="color:inherit;">{t('info.location.val')}</a
          >
          <p class="info-strip__sub">{t('info.location.sub')}</p>
        </div>
        <div>
          <p class="eyebrow">{t('info.hours.label')}</p>
          <p class="info-strip__val">{t('info.hours.val')}</p>
          <p class="info-strip__sub">{t('info.hours.sub')}</p>
        </div>
        <div>
          <p class="eyebrow">{t('info.res.label')}</p>
          <p class="info-strip__val">{site.contact.phoneDisplay}</p>
          <p class="info-strip__sub">{t('info.res.sub')}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
