---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../CtaBanner.astro';
import { useTranslations, langBase } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { site } from '../../lib/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = langBase(lang);
---

<BaseLayout title={t('home.seo.title')} description={t('home.seo.desc')} lang={lang}>
  <!-- Hero -->
  <section class="hero">
    <video class="hero__bg" src="/images/brand/hero.mp4" autoplay muted loop playsinline></video>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__eyebrow">{t('hero.eyebrow')}</p>
      <h1 class="hero__title">
        {t('hero.title1')}<br /><em>{t('hero.title2')}</em>
      </h1>
      <p class="hero__subtitle">{t('hero.subtitle')}</p>
      <div class="hero__actions">
        <a href={base + '/menu'} class="btn btn--gold">{t('hero.cta1')}</a>
        <a href={base + '/contact'} class="btn btn--outline-light">{t('hero.cta2')}</a>
      </div>
    </div>
    <div class="hero__scroll">
      <div class="hero__scroll-line"></div>
      <span>{t('hero.scroll')}</span>
    </div>
  </section>

  <!-- About strip -->
  <section class="about-strip">
    <div class="about-strip__image">
      <img
        src="/images/brand/sign.jpg"
        alt="The OIKOS sign on a marble wall with guests in the foreground"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="about-strip__content">
      <p class="eyebrow">{t('home.about.eyebrow')}</p>
      <div class="divider"></div>
      <h2 class="section-title">
        {t('home.about.title1')}<br />{t('home.about.title2')}
      </h2>
      <p>{t('home.about.text')}</p>
      <a href={base + '/about'} class="btn btn--outline">{t('home.about.cta')}</a>
    </div>
  </section>

  <!-- Services -->
  <section>
    <div class="services">
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/food/brunch.jpg"
            alt="Poached eggs with halloumi and salad at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">{t('svc.brunch.title')}</h3>
          <p class="service-card__desc">{t('svc.brunch.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/food/sushi.jpg"
            alt="Freshly prepared sushi rolls at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">{t('svc.sushi.title')}</h3>
          <p class="service-card__desc">{t('svc.sushi.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/food/risotto.jpg"
            alt="Risotto dish at OIKOS"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">{t('svc.lunch.title')}</h3>
          <p class="service-card__desc">{t('svc.lunch.desc')}</p>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card__media">
          <img
            src="/images/drinks/cocktail.jpg"
            alt="Craft cocktail with bitters at the OIKOS bar"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">{t('svc.cocktails.title')}</h3>
          <p class="service-card__desc">{t('svc.cocktails.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section section--dark">
    <div class="container">
      <div class="container--narrow">
        <p class="eyebrow">{t('reviews.eyebrow')}</p>
        <div class="divider divider--centered"></div>
        <h2 class="section-title">
          {t('reviews.title1')}<br />{t('reviews.title2')}
        </h2>
        <a
          href={site.googleReviews}
          target="_blank"
          rel="noopener noreferrer"
          class="google-rating"
        >
          <span class="google-rating__score">4.7</span>
          <span class="google-rating__stars" aria-label="5 out of 5 stars" role="img">★★★★★</span>
          <span class="google-rating__count">330 {t('reviews.google')}</span>
        </a>
      </div>

      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "All the food we tasted was delicious. With the coffee and shakes, it was amazing… I
            definitely recommend it."
          </p>
          <span class="review-card__author">Stano Bagin · {t('reviews.guide')}</span>
        </div>
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "Food was delicious ✨ wine was also good. The lemon pie is enormous — share it with
            three people! I really recommend the salmon with couscous."
          </p>
          <span class="review-card__author">Anys Hruba · {t('reviews.guide')}</span>
        </div>
        <div class="review-card">
          <div class="review-card__stars" aria-label="5 out of 5 stars" role="img">★★★★★</div>
          <p class="review-card__text">
            "The food here is absolutely amazing. We came for breakfast 3 times and for lunch 1 time
            and everything was perfect. So tasty and the service amazing. Recommend for everyone."
          </p>
          <span class="review-card__author">Petros Isaias · {t('reviews.guide')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section section--cream">
    <div class="container--narrow" style="margin-bottom: var(--space-12);">
      <p class="eyebrow">{t('gallery.eyebrow')}</p>
      <div class="divider divider--centered"></div>
      <h2 class="section-title">
        {t('gallery.title1')}<br />{t('gallery.title2')}
      </h2>
    </div>
    <div class="container">
      <div class="gallery-mosaic">
        <div class="gallery-mosaic__item gallery-mosaic__item--placeholder"></div>
        <div class="gallery-mosaic__item gallery-mosaic__item--placeholder"></div>
        <div class="gallery-mosaic__item gallery-mosaic__item--placeholder"></div>
        <div class="gallery-mosaic__item gallery-mosaic__item--placeholder"></div>
        <div class="gallery-mosaic__item gallery-mosaic__item--placeholder"></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner title={t('cta.title')} subtitle={t('cta.subtitle')}>
    <div class="cta-actions">
      <a href={`tel:${site.phoneTel}`} class="btn btn--dark">{t('cta.call')}</a>
      <a href={base + '/menu'} class="btn btn--outline">{t('cta.menu')}</a>
    </div>
  </CtaBanner>

  <!-- Info strip -->
  <section class="section section--mid section--centered">
    <div class="container">
      <div class="info-strip">
        <div>
          <p class="eyebrow">{t('info.location.label')}</p>
          <p class="info-strip__val">{t('info.location.val')}</p>
          <p class="info-strip__sub">{t('info.location.sub')}</p>
        </div>
        <div>
          <p class="eyebrow">{t('info.hours.label')}</p>
          <p class="info-strip__val">{t('info.hours.val')}</p>
          <p class="info-strip__sub">{t('info.hours.sub')}</p>
        </div>
        <div>
          <p class="eyebrow">{t('info.res.label')}</p>
          <p class="info-strip__val">{site.phoneDisplay}</p>
          <p class="info-strip__sub">{t('info.res.sub')}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
