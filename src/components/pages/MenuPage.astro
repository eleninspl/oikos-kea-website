---
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../PageHero.astro';
import CtaBanner from '../CtaBanner.astro';
import { useTranslations, getLabel } from '../../i18n/utils';
import { getMenu } from '../../lib/sanity';
import MenuItem from '../MenuItem.astro';
import type { Lang } from '../../i18n/utils';
import { site } from '../../lib/site';
import risottoImg from '../../assets/images/food/risotto.jpg';
import cocktailImg from '../../assets/images/drinks/cocktail.jpg';

// Δύο tab fallbacks μετακινήθηκαν στο src/assets → βελτιστοποιημένα thumbnails.
const [risottoThumb, cocktailThumb] = await Promise.all([
  getImage({ src: risottoImg, width: 176, format: 'webp' }),
  getImage({ src: cocktailImg, width: 176, format: 'webp' }),
]);

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const gl = (el: string, en: string) => getLabel(lang, el, en);

const menuTabs = await getMenu();

// Τοπικές φωτογραφίες ανά καρτέλα — fallback όταν το CMS δεν έχει εικόνα.
const tabImageFallback: Record<string, string> = {
  coffee: '/images/drinks/smoothies.webp',
  brunch: '/images/food/brunch.jpg',
  sushi: '/images/food/sushi.jpg',
  cocktails: cocktailThumb.src,
  'lunch-dinner': risottoThumb.src,
  spirits: '/images/drinks/beer.jpg',
  wines: '/images/drinks/wine.jpg',
};
---

<BaseLayout title={t('menu.seo.title')} description={t('menu.seo.desc')} lang={lang}>
  <PageHero eyebrow={t('menu.eyebrow')} title={t('menu.title')} subtitle={t('menu.subtitle')} />

  <section class="section section--cream">
    <div class="container">
      <div class="menu-tabs" id="menu-tabs" data-view="grid">
        <!-- Πλέγμα μεγάλων κουμπιών (μία καρτέλα ανά κουμπί) -->
        <div class="menu-nav">
          {
            menuTabs.map((tab) => (
              <button
                type="button"
                class="menu-tab-btn"
                data-panel={`panel-${tab.key}`}
                aria-controls={`panel-${tab.key}`}
              >
                <img
                  class="menu-tab-img"
                  src={tab.image ?? tabImageFallback[tab.key] ?? '/images/ui/menu-placeholder.svg'}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width="96"
                  height="96"
                />
                <span class="menu-tab-label">{gl(tab.labelEl, tab.labelEn)}</span>
              </button>
            ))
          }
        </div>

        <!-- Πίσω στις κατηγορίες (φαίνεται μόνο στην οθόνη λεπτομέρειας) -->
        <button class="menu-back" id="menu-back" type="button">
          <span aria-hidden="true">←</span>
          {gl('Όλες οι κατηγορίες', 'All categories')}
        </button>

        <!-- Οθόνες περιεχομένου -->
        {
          menuTabs.map((tab) => (
            <div class="menu-panel" id={`panel-${tab.key}`}>
              <h2 class="menu-panel-title" tabindex="-1">
                {gl(tab.labelEl, tab.labelEn)}
              </h2>
              {(tab.noteEl || tab.noteEn) && (
                <p class="menu-panel-note">{gl(tab.noteEl ?? '', tab.noteEn ?? '')}</p>
              )}
              {tab.sections.map((section) => (
                <div class="menu-section">
                  <div class="menu-section-header">
                    <h3 class="menu-category">{gl(section.titleEl, section.titleEn)}</h3>
                    <span class="menu-section-line" aria-hidden="true" />
                  </div>
                  {(section.noteEl || section.noteEn) && (
                    <p class="menu-section-note">
                      {gl(section.noteEl ?? '', section.noteEn ?? '')}
                    </p>
                  )}

                  <div class="menu-section__body">
                    {section.subsections?.length ? (
                      section.subsections.map((sub) => (
                        <div class="menu-subsection">
                          {(sub.titleEl || sub.titleEn) && (
                            <h4 class="menu-subsection-title">
                              {gl(sub.titleEl ?? '', sub.titleEn ?? '')}
                              {sub.sectionPrice && (
                                <span class="menu-subsection-price"> — {sub.sectionPrice}</span>
                              )}
                            </h4>
                          )}
                          <div class="menu-grid">
                            {sub.items.map((item) => (
                              <MenuItem item={item} lang={lang} />
                            ))}
                          </div>
                        </div>
                      ))
                    ) : (
                      <div class="menu-grid">
                        {section.items?.map((item) => (
                          <MenuItem item={item} lang={lang} />
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          ))
        }

        <!-- Disclaimer (μόνο στην οθόνη λεπτομέρειας) -->
        <div class="menu-disclaimer">
          <p class="eyebrow" style="margin-bottom:var(--space-3);">{t('menu.note.eyebrow')}</p>
          <p>{t('menu.disclaimer')}</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner title={t('menu.cta.title')} subtitle={t('menu.cta.subtitle')}>
    <a href={`tel:${site.contact.phoneTel}`} class="btn btn--dark">{t('menu.cta.btn')}</a>
  </CtaBanner>
</BaseLayout>

<script>
  // ── Drill-down navigation: πλέγμα κουμπιών ⇄ οθόνη κατηγορίας ──
  const root = document.getElementById('menu-tabs')!;
  const btns = document.querySelectorAll<HTMLButtonElement>('.menu-tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.menu-panel');
  const back = document.getElementById('menu-back');

  function scrollMenuTop() {
    const top = root.getBoundingClientRect().top + window.scrollY - 90;
    window.scrollTo({ top: Math.max(0, top) });
  }

  function showGrid() {
    root.dataset.view = 'grid';
    panels.forEach((p) => p.classList.remove('active'));
  }

  function showDetail(key: string | null | undefined): boolean {
    if (!key) return false;
    const panel = document.getElementById(`panel-${key}`);
    if (!panel) return false;
    panels.forEach((p) => p.classList.remove('active'));
    panel.classList.add('active');
    root.dataset.view = 'detail';
    return true;
  }

  function sync() {
    const key = location.hash.slice(1);
    if (showDetail(key)) {
      scrollMenuTop();
      // Μετέφερε το focus στον τίτλο της καρτέλας ώστε χρήστες πληκτρολογίου/
      // screen reader να «προσγειώνονται» στο νέο περιεχόμενο (preventScroll:
      // αφήνουμε το scrollMenuTop να ελέγχει τη θέση λόγω του fixed nav).
      const heading = document
        .getElementById(`panel-${key}`)
        ?.querySelector<HTMLElement>('.menu-panel-title');
      heading?.focus({ preventScroll: true });
    } else {
      showGrid();
    }
  }

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.panel?.replace('panel-', '');
      if (key) location.hash = key; // αλλάζει το hash → sync· το «πίσω» επιστρέφει στο πλέγμα
    });
  });

  back?.addEventListener('click', () => {
    // Αφαίρεσε το hash χωρίς να φύγεις από το site. Σκέτο history.back() θα
    // έβγαζε εκτός σελίδας όταν η σελίδα φορτώθηκε απευθείας σε #κατηγορία
    // (κοινόχρηστος σύνδεσμος ή αλλαγή γλώσσας που μεταφέρει το hash).
    if (location.hash) history.pushState('', '', location.pathname + location.search);
    showGrid();
  });

  sync();
  window.addEventListener('hashchange', sync);

  // ── Image lightbox ──────────────────────────────────────────────────────────
  const lightbox = document.createElement('div');
  lightbox.className = 'img-lightbox';
  const lbImg = document.createElement('img');
  lbImg.className = 'img-lightbox__img';
  lbImg.alt = '';
  lightbox.appendChild(lbImg);
  document.body.appendChild(lightbox);

  function openLightbox(src: string) {
    lbImg.src = src;
    lightbox.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    const img = (e.target as Element).closest('.menu-item__img');
    if (img instanceof HTMLImageElement) {
      openLightbox(img.src);
    } else if (lightbox.classList.contains('is-open')) {
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style>
  /* ─── Menu page — drill-down: πλέγμα μεγάλων κουμπιών ⇄ οθόνη κατηγορίας ─── */
  .menu-nav {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-4);
    max-width: 100%;
    margin: 0 auto;
  }

  /* Κάρτα-κουμπί: φωτό αριστερά + τίτλος δίπλα */
  .menu-tab-btn {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    text-align: left;
    padding: var(--space-3);
    background: transparent;
    border: 1px solid rgb(from var(--brand-ink) r g b / 0.18);
    border-radius: var(--radius-md);
    cursor: pointer;
    overflow: hidden;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.1s ease;
  }
  .menu-tab-img {
    width: 88px;
    height: 88px;
    flex-shrink: 0;
    object-fit: cover;
    border-radius: var(--radius-sm);
    background-color: var(--color-cream-alt);
  }
  .menu-tab-label {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text-dark);
    line-height: 1.2;
  }
  .menu-tab-btn:hover {
    border-color: var(--color-gold);
    background-color: rgb(from var(--brand-accent) r g b / 0.12);
  }
  .menu-tab-btn:active {
    transform: scale(0.98);
  }

  /* «Πίσω» κουμπί — μόνο στην οθόνη λεπτομέρειας */
  .menu-back {
    display: none;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-dark);
    background: transparent;
    border: 1px solid rgb(from var(--brand-ink) r g b / 0.18);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }
  .menu-back:hover {
    border-color: var(--color-gold);
    background-color: rgb(from var(--brand-accent) r g b / 0.12);
  }

  .menu-panel-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-3);
    color: var(--text-dark);
  }

  .menu-panel-title:focus:not(:focus-visible) {
    outline: none;
  }

  .menu-panel-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: var(--space-10);
  }

  .menu-panel {
    display: none;
  }

  /* Εναλλαγή όψεων μέσω data-view στο .menu-tabs (το JS ορίζει data-view/.active) */
  .menu-tabs[data-view='detail'] .menu-nav {
    display: none;
  }
  .menu-tabs[data-view='detail'] .menu-back {
    display: inline-flex;
  }
  .menu-tabs[data-view='detail'] .menu-panel.active {
    display: block;
  }
  .menu-tabs[data-view='grid'] .menu-disclaimer {
    display: none;
  }

  /* ─── Menu page — sections ─── */
  .menu-section {
    margin-bottom: var(--space-12);
  }

  .menu-section-header {
    width: 100%;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
    background: none;
    border: none;
    padding: 0;
    text-align: left;
    cursor: default;
    color: inherit;
  }

  .menu-section-line {
    flex: 1;
    height: 1px;
    background-color: rgb(from var(--brand-ink) r g b / 0.1);
  }

  /* Σημείωση κατηγορίας (π.χ. «όλα τα milkshakes €6,50») — κάτω από τον τίτλο */
  .menu-section-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-style: italic;
    margin-top: calc(-1 * var(--space-2));
    margin-bottom: var(--space-6);
  }

  .menu-category {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    white-space: nowrap;
    display: flex;
    align-items: center;
  }

  .menu-subsection {
    margin-bottom: var(--space-10);
  }

  .menu-subsection-title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px dashed rgb(from var(--brand-ink) r g b / 0.15);
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--space-12);
    row-gap: 0;
  }

  .menu-disclaimer {
    margin-top: var(--space-8);
    padding-block: var(--space-8);
    border-top: 1px solid rgb(from var(--brand-ink) r g b / 0.1);
    max-width: 52rem;
    color: var(--text-muted);
    font-size: var(--text-xs);
    line-height: 1.7;
  }
  /* Κάθε γραμμή της σημείωσης = bullet */
  .menu-disclaimer p:last-child {
    white-space: pre-line;
  }

  /* ─── Menu page — mobile ─── */
  @media (max-width: 768px) {
    .menu-section {
      margin-bottom: var(--space-10);
    }

    .menu-section-header {
      margin-bottom: var(--space-4);
    }

    .menu-section-header .menu-category {
      font-size: var(--text-2xl);
      white-space: normal;
      line-height: 1.15;
    }

    .menu-section-line {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .menu-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .menu-nav {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .menu-tab-btn {
      min-height: 90px;
      font-size: var(--text-base);
      padding: var(--space-4) var(--space-3);
    }

    .menu-category {
      font-size: var(--text-2xl);
    }
  }
</style>

<!-- is:global: το lightbox δημιουργείται από JS και προστίθεται στο <body>,
     εκτός του scope του component — οπότε χρειάζεται global styles. -->
<style is:global>
  /* ── Image lightbox ── */
  .img-lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(20, 18, 15, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .img-lightbox.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .img-lightbox__img {
    max-width: min(680px, 92vw);
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    transform: scale(0.92);
    transition: transform 0.25s ease;
  }

  .img-lightbox.is-open .img-lightbox__img {
    transform: scale(1);
  }
</style>
