---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, getLabel } from '../../i18n/utils';
import { getMenu } from '../../lib/sanity';
import MenuItem from '../MenuItem.astro';
import type { Lang } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const gl = (el: string, en: string) => getLabel(lang, el, en);

const menuTabs = await getMenu();
---

<BaseLayout title={t('menu.seo.title')} description={t('menu.seo.desc')} lang={lang}>
  <div class="page-hero">
    <p class="eyebrow">{t('menu.eyebrow')}</p>
    <h1 class="page-hero__title">{t('menu.title')}</h1>
    <p class="page-hero__sub">{t('menu.subtitle')}</p>
  </div>

  <section class="section section--cream">
    <div class="container">

      <div class="menu-tabs" id="menu-tabs" data-view="grid">
        <!-- Πλέγμα μεγάλων κουμπιών (μία καρτέλα ανά κουμπί) -->
        <div class="menu-nav" role="tablist">
          {menuTabs.map((tab) => (
            <button
              role="tab"
              class="menu-tab-btn"
              data-panel={`panel-${tab.key}`}
              aria-selected="false"
            >
              <img
                class="menu-tab-img"
                src={tab.image ?? '/images/menu-placeholder.svg'}
                alt=""
                loading="lazy"
                width="96"
                height="96"
              />
              <span class="menu-tab-label">{gl(tab.labelEl, tab.labelEn)}</span>
            </button>
          ))}
        </div>

        <!-- Πίσω στις κατηγορίες (φαίνεται μόνο στην οθόνη λεπτομέρειας) -->
        <button class="menu-back" id="menu-back" type="button">
          <span aria-hidden="true">←</span> {gl('Όλες οι κατηγορίες', 'All categories')}
        </button>

        <!-- Οθόνες περιεχομένου -->
        {menuTabs.map((tab) => (
          <div class="menu-panel" id={`panel-${tab.key}`} role="tabpanel">
            <h2 class="menu-panel-title">{gl(tab.labelEl, tab.labelEn)}</h2>
            {tab.sections.map((section) => (
              <div class="menu-section">
                <div class="menu-section-header">
                  <h2 class="menu-category">
                    {gl(section.titleEl, section.titleEn)}
                  </h2>
                  <span class="menu-section-line" aria-hidden="true"></span>
                </div>

              <div class="menu-section__body">
                {section.subsections ? (
                  section.subsections.map((sub) => (
                    <div class="menu-subsection">
                      {(sub.titleEl || sub.titleEn) && (
                        <h3 class="menu-subsection-title">
                          {gl(sub.titleEl ?? '', sub.titleEn ?? '')}
                          {sub.sectionPrice && (
                            <span class="menu-subsection-price"> — {sub.sectionPrice}</span>
                          )}
                        </h3>
                      )}
                      <div class="menu-grid">
                        {sub.items.map((item) => <MenuItem item={item} lang={lang} />)}
                      </div>
                    </div>
                  ))
                ) : (
                  <div class="menu-grid">
                    {section.items?.map((item) => <MenuItem item={item} lang={lang} />)}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
        ))}

        <!-- Disclaimer (μόνο στην οθόνη λεπτομέρειας) -->
        <div class="menu-disclaimer">
          <p class="eyebrow" style="margin-bottom:var(--space-3);">{t('menu.note.eyebrow')}</p>
          <p>{t('menu.disclaimer')}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2 class="section-title">{t('menu.cta.title')}</h2>
      <p>{t('menu.cta.subtitle')}</p>
      <a href="tel:+302288022507" class="btn btn--dark">{t('menu.cta.btn')}</a>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Drill-down navigation: πλέγμα κουμπιών ⇄ οθόνη κατηγορίας ──
  const root = document.getElementById('menu-tabs')!;
  const btns = document.querySelectorAll<HTMLButtonElement>('.menu-tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.menu-panel');
  const back = document.getElementById('menu-back');

  function scrollMenuTop() {
    const top = root.getBoundingClientRect().top + window.scrollY - 90;
    window.scrollTo({ top: Math.max(0, top) });
  }

  function showGrid() {
    root.dataset.view = 'grid';
    panels.forEach(p => p.classList.remove('active'));
    btns.forEach(b => b.setAttribute('aria-selected', 'false'));
  }

  function showDetail(key: string | null | undefined): boolean {
    if (!key) return false;
    const panel = document.getElementById(`panel-${key}`);
    if (!panel) return false;
    panels.forEach(p => p.classList.remove('active'));
    panel.classList.add('active');
    btns.forEach(b => b.setAttribute('aria-selected', b.dataset.panel === `panel-${key}` ? 'true' : 'false'));
    root.dataset.view = 'detail';
    return true;
  }

  function sync() {
    const key = location.hash.slice(1);
    if (showDetail(key)) scrollMenuTop();
    else showGrid();
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.panel?.replace('panel-', '');
      if (key) location.hash = key; // αλλάζει το hash → sync· το «πίσω» επιστρέφει στο πλέγμα
    });
  });

  back?.addEventListener('click', () => {
    if (location.hash) history.back();
    else showGrid();
  });

  sync();
  window.addEventListener('hashchange', sync);
</script>
